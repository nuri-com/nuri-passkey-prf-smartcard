#!/usr/bin/env bash
# nuricard: one console entry for every smartcard function in this repo.
# No args -> walk-through menu (idiot-proof). With args -> forwards to npm scripts.
set -euo pipefail

# Resolve repo root even when called through an npm-link symlink.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$ROOT"

export GP_READER="${GP_READER:-2}"   # contact reader index on this setup

# label|command   (command "H" means it is a section header, not selectable)
ENTRIES=(
  "H|TOTP  (2FA codes, e.g. Hetzner)"
  "Show current 6-digit code|totp_code"
  "Store / replace secret on card|totp_put"
  "Install TOTP applet on card|card:totp:install"
  "Build TOTP applet CAP|card:totp:build"

  "H|FIDO2 / Passkey"
  "WebAuthn PRF card test|card:test"
  "WebAuthn PRF card test (PIN/UV required)|card:test:pin"
  "PIN status|card:pin:status"
  "Set PIN|card:pin:set"
  "Change PIN|card:pin:change"
  "Verify PIN|card:pin:verify"
  "Reset FIDO2 state (DESTRUCTIVE)|RESET"
  "Build FIDO2 CAP|card:build"
  "Install FIDO2 CAP|card:install"
  "Reinstall FIDO2 CAP (DESTRUCTIVE)|REINSTALL"
  "CTAP makeCredential matrix|card:ctap:makecred-matrix"
  "HID transport test|hid:test"

  "H|WebAuthn PRF  (offline backup)"
  "Card info / capabilities|card:prf:info"
  "Enroll PRF credential|card:prf:enroll"
  "Derive PRF secret|card:prf:derive"
  "PRF stability selftest|card:prf:selftest"

  "H|Bitcoin / MuSig2  (card cosigner)"
  "Show card Bitcoin address|bitcoin:card:address"
  "Show card UTXOs|bitcoin:card:utxos"
  "Build + sign spend (no broadcast)|bitcoin:card:spend"
  "Check tx status|bitcoin:card:status"
  "Install MuSig2 applet|card:musig2:install"
  "Test MuSig2 applet|card:musig2:test"
  "Real-card cosign proof|cosign:real-card"
  "Real-card cosign keygen proof|cosign:real-card:keygen"

  "H|Simulators / server cosigner"
  "MuSig2 simulator demo|musig2:demo"
  "Cosign simulator selftest|cosign:demo"
  "Server cosigner (software)|server:cosigner:software"
  "Server cosigner (card-sim)|server:cosigner:card-sim"
  "Server cosigner (apdu-sim)|server:cosigner:apdu-sim"
  "Full CLI end-to-end|cli:e2e"
  "Unit tests|test"

  "H|Web / Mobile PRF"
  "Serve browser PRF page|web:prf"
  "Serve PRF page via ngrok|web:tunnel"
  "Android NFC PRF probe|mobile:android"
  "iOS NFC PRF probe|mobile:ios"

  "H|Card maintenance"
  "List installed applets|APPLETS"
  "Show ALL raw npm commands|ALLCMDS"
)

run() { echo "+ npm run $*" >&2; npm run --silent "$@"; }
pause() { echo; read -r -p "Press Enter to return to the menu..." _ || true; }
confirm() { local a; read -r -p "$1 Type YES to continue: " a || true; [ "$a" = "YES" ]; }

dispatch() {
  case "$1" in
    totp_code) run card:totp -- code ;;
    totp_put)
      local s; read -r -p "BASE32 secret: " s || true
      if [ -n "${s// /}" ]; then run card:totp -- put "$s"; else echo "No secret entered, aborted."; fi ;;
    APPLETS) gp -r "$GP_READER" -l 2>&1 | grep -E 'APP:|PKG:' || true ;;
    ALLCMDS) npm run 2>/dev/null | grep -E '^  [a-z]' || true ;;
    RESET)
      if confirm "This WIPES all FIDO2 credentials/state on the card."; then
        FIDO2_RESET_CONFIRM=YES npm run --silent card:reset
      else echo "Cancelled."; fi ;;
    REINSTALL)
      if confirm "This DELETES and reinstalls the FIDO2 applet."; then
        FIDO2_REINSTALL_CONFIRM=YES npm run --silent card:reinstall
      else echo "Cancelled."; fi ;;
    *) run "$1" ;;
  esac
}

menu() {
  while true; do
    clear 2>/dev/null || true
    echo "============================================"
    echo "   nuricard — Nuri Smartcard"
    echo "============================================"
    local -a cmds=()
    local n=0 label cmd
    for e in "${ENTRIES[@]}"; do
      label="${e%%|*}"; cmd="${e#*|}"
      if [ "$label" = "H" ]; then
        printf "\n  %s\n" "$cmd"
      else
        n=$((n + 1)); cmds[$n]="$cmd"
        printf "   %2d) %s\n" "$n" "$label"
      fi
    done
    printf "\n    0) Quit\n"
    echo "============================================"
    local choice
    read -r -p "Select [0-$n]: " choice || exit 0
    if ! [[ "$choice" =~ ^[0-9]+$ ]]; then echo "Please enter a number."; sleep 1; continue; fi
    if [ "$choice" = "0" ]; then echo "Bye."; exit 0; fi
    if [ "$choice" -lt 1 ] || [ "$choice" -gt "$n" ]; then echo "Out of range: $choice"; sleep 1; continue; fi
    echo
    dispatch "${cmds[$choice]}" || true
    pause
  done
}

cmd="${1:-}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
  ""|menu)
    menu ;;
  help|--help|-h)
    echo "nuricard                    interactive menu (idiot-proof)"
    echo "nuricard totp               current TOTP code from the card"
    echo "nuricard totp put \"BASE32\"   store a TOTP secret on the card"
    echo "nuricard <npm-script> [-- args]   run any command from package.json"
    echo
    npm run 2>/dev/null | grep -E '^  [a-z]' || true ;;
  totp)
    if [ "${1:-}" = "put" ]; then shift; exec npm run --silent card:totp -- put "$@"; fi
    exec npm run --silent card:totp -- code "$@" ;;
  *)
    exec npm run --silent "$cmd" -- "$@" ;;
esac
