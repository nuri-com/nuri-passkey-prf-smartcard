{
  "name": "expo-nfc-prf-probe",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:profile": "../../scripts/run-expo-nfc-prf-probe.sh start",
    "prebuild": "expo prebuild",
    "android": "expo run:android",
    "android:profile": "../../scripts/run-expo-nfc-prf-probe.sh android",
    "android:server": "expo start --android --dev-client",
    "ios": "expo run:ios",
    "ios:profile": "../../scripts/run-expo-nfc-prf-probe.sh ios --device",
    "ios:server": "expo start --ios --dev-client",
    "web": "expo start --web",
    "check:design-system": "node scripts/check-design-system-ui.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arkade-os/boltz-swap": "^0.3.43",
    "@arkade-os/sdk": "^0.4.38",
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@nuri/rn": "file:../../.build/nuri-design-system/packages/rn",
    "@nuri/spec": "file:../../.build/nuri-design-system/packages/spec",
    "@scure/base": "^1.1.7",
    "@scure/btc-signer": "2.2.0",
    "base64-js": "1.5.1",
    "cborg": "5.1.1",
    "eventsource": "^4.1.0",
    "expo": "^57.0.4",
    "expo-clipboard": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "^19.2.3",
    "react-native": "^0.86.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-nfc-manager": "4.0.0-beta.7",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "uuid": "^11.1.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager",
          "@arkade-os/sdk",
          "@arkade-os/boltz-swap",
          "eventsource"
        ]
      }
    }
  }
}
