{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "paths": {
      "@nuri/rn": ["./node_modules/@nuri/rn/index.ts"],
      "@nuri/rn/*": ["./node_modules/@nuri/rn/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
